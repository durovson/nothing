# Application / FastAPI
APP_NAME=Gift Guarant
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=https://your-app.onrender.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_USE_POLLING=true
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=replace_with_a_random_32_char_secret
SUPPORT_USERNAME=@ton_geist

# Supabase: only a server-side service-role key is allowed here.
SUPABASE_URL=
SUPABASE_KEY=

# TON / TonAPI
TON_API_ENDPOINT=https://tonapi.io/v2
TON_API_KEY=
TON_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24
TON_NETWORK=mainnet
TON_WORKCHAIN=0
TON_REQUEST_TIMEOUT_MS=15000
TON_TRANSFER_TTL_SECONDS=60
TON_TRACE_GRACE_SECONDS=120
TON_TRANSACTION_SCAN_LIMIT=50

# Deal rules and background jobs
DEAL_POLL_INTERVAL_SECONDS=15
DEAL_PAYMENT_TIMEOUT_SECONDS=900
FAILED_DEAL_RETENTION_DAYS=30
RETENTION_CLEANUP_INTERVAL_SECONDS=86400
ESCROW_FEE_RATE=0.03
REFERRAL_FEE_SHARE=0.01
AUTO_PAYOUT_AFTER_PAYMENT=true
DEALS_PAGE_SIZE=8
DEFAULT_LANGUAGE=ru
